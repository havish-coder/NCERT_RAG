# ── LLM (any OpenAI-compatible endpoint: local Ollama, Gemini, Groq, OpenAI) ──
# Local Ollama (default):
ONLINE_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
ONLINE_MODEL=qwen2.5:7b-instruct
#
# Google Gemini (free tier) — uncomment and set your key from aistudio.google.com/apikey:
# ONLINE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your-gemini-api-key
# ONLINE_MODEL=gemini-2.5-flash

# Offline entity/relationship extraction model (HuggingFace, GPU only).
OFFLINE_EXTRACTION_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cuda   # set to 'cpu' if no GPU locally

# ── Neo4j (Community Edition only has the default 'neo4j' database) ────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_CHUNKS_COLLECTION=ncert_chunks
QDRANT_ENTITIES_COLLECTION=ncert_entities

# ── Graph ─────────────────────────────────────────────────────────────────────
MAX_ENTITY_NEIGHBORS=10

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_CHUNKS=10
TOP_K_ENTITIES=5
CONTEXT_TOKEN_BUDGET=8192

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console   # console | json
